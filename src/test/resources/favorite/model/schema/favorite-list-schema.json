{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "productFileUrl": {
            "type": ["string", "null"]
          }
        },
        "required": ["id", "name", "price"]
      }
    }
  },
  "required": ["products"]
}
